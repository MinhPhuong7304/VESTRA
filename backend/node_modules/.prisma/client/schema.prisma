generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id
  username       String?  @unique
  email          String?  @unique
  phone          String?
  password       String?
  full_name      String?
  gender         String?
  birth_date     String?
  user_type      String?  @default("customer") // "customer", "admin", "shop", "staff"
  account_status String?  @default("active") // "active", "suspended"
  avatar_url     String?  @db.Text
  wallet_address String?  @unique // Địa chỉ ví Blockchain giám hộ công khai
  avatar_3d_url  String?  @db.Text // Đường dẫn file model 3D cá nhân (.glb/gltf)
  body_image_url String?  @db.Text // Đường dẫn ảnh chụp toàn thân để chạy VTO 2D
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  addresses   Address[]
  owned_store Store?    @relation("StoreOwner")
  store_id    String?
  workplace   Store?    @relation("StoreStaff", fields: [store_id], references: [id], onDelete: SetNull)

  videos        Video[]
  vto_sessions  VtoSession[]
  pass_products Product[]      @relation("UserPassProducts")
  orders        Order[]
  cart          Cart?
  reviews       Review[]
  chat_messages ChatMessage[]
  notifications Notification[]
}

model Store {
  id             String   @id
  name           String
  description    String?  @db.Text
  logo_url       String?  @db.Text
  owner_id       String   @unique
  status         String   @default("Hoạt động") // "Hoạt động", "Tạm dừng"
  wallet_address String?  @unique // Địa chỉ ví Blockchain của Shop để nhận tiền
  created_at     DateTime @default(now())

  owner    User      @relation("StoreOwner", fields: [owner_id], references: [id], onDelete: Cascade)
  staff    User[]    @relation("StoreStaff")
  products Product[]
  orders   Order[]
}

model Address {
  id           String  @id
  user_id      String?
  address_line String?
  city         String?
  district     String?
  ward         String?
  is_default   Boolean @default(false)

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)
}

model Category {
  id          String   @id
  name        String
  images      String?  @db.Text
  description String?  @db.Text
  isActive    Boolean  @default(true)
  created_at  DateTime @default(now())

  products Product[]
}

model Product {
  id             String   @id
  name           String
  category_id    String?
  description    String?  @db.Text
  stock          Int      @default(0)
  price_sale     Int      @default(0)
  price_cost     Int      @default(0)
  sold           Int      @default(0)
  status         String?  @default("active") // "active", "hidden"
  store_id       String?
  is_pass_item   Boolean  @default(false) // Phân biệt hàng New (B2C) và hàng Pass (C2C)
  owner_id       String? // Trỏ trực tiếp tới User nếu là đồ Pass của Khách hàng
  condition      Int? // Độ mới (ví dụ: 95, 99%)
  is_vto_enabled Boolean  @default(false) // Sản phẩm có hỗ trợ thử đồ online không
  garment_3d_url String?  @db.Text // Đường dẫn file 3D của trang phục (.glb, .gltf)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  category Category? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  store    Store?    @relation(fields: [store_id], references: [id], onDelete: SetNull)
  owner    User?     @relation("UserPassProducts", fields: [owner_id], references: [id], onDelete: SetNull)

  images      ProductImage[]
  variants    ProductVariant[]
  order_items OrderItem[]
  cart_items  CartItem[]
  videos      Video[]
  reviews     Review[]
}

model ProductImage {
  id         Int    @id @default(autoincrement())
  product_id String
  image_url  String @db.Text

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id           String  @id
  product_id   String
  color        String?
  size         String?
  quantity     Int     @default(0)
  sold         Int     @default(0)
  price_import Int     @default(0)
  price_sale   Int     @default(0)

  product     Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  order_items OrderItem[]
  cart_items  CartItem[]
}

model Banner {
  id            String   @id
  title         String?
  image_url     String?  @db.Text
  link_url      String?
  click_count   Int      @default(0)
  display_order Int?
  description   String?  @db.Text
  status        String?  @default("active")
  created_at    DateTime @default(now())
}

model Voucher {
  id              String    @id
  code            String    @unique
  description     String?   @db.Text
  discount_type   String // "PERCENT", "FIXED"
  discount_value  Int       @default(0)
  max_discount    Int?
  min_order_value Int       @default(0)
  start_date      DateTime?
  end_date        DateTime?
  status          String    @default("ACTIVE") // "ACTIVE", "EXPIRED", "DISABLED"
  created_at      DateTime  @default(now())

  orders Order[]
}

model Shift {
  id          String  @id
  staffId     String?
  staffName   String?
  date        String?
  startTime   String?
  endTime     String?
  note        String?
  statusColor String?
}

model Chat {
  id             String   @id
  customer_id    String?
  customer_name  String?
  customer_email String?
  chat_status    String?  @default("open")
  started_at     DateTime @default(now())
  last_message   String?  @db.Text
  updated_at     DateTime @updatedAt
  unread         Int      @default(0)

  messages ChatMessage[]
}

model ChatMessage {
  id              String   @id
  chat_id         String
  sender_id       String?
  sender_type     String? // "customer", "staff", "shop"
  message_content String?  @db.Text
  sent_at         DateTime @default(now())

  chat   Chat  @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  sender User? @relation(fields: [sender_id], references: [id], onDelete: SetNull)
}

model Review {
  id          String   @id
  product_id  String
  customer_id String
  rating      Int
  comment     String?  @db.Text
  created_at  DateTime @default(now())

  product  Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  customer User    @relation(fields: [customer_id], references: [id], onDelete: Cascade)
}

model Order {
  id               String   @id
  user_id          String?
  customer_name    String?
  customer_phone   String?
  customer_email   String?
  shipping_address String?  @db.Text
  total_amount     Int
  status           String   @default("PENDING") // "PENDING", "PROCESSING", "SHIPPED", "DELIVERED", "CANCELLED", "REFUNDED"
  payment_method   String // "COD", "VNPAY", "MOMO", "WALLET"
  payment_status   String   @default("UNPAID") // "UNPAID", "PAID", "REFUNDED"
  store_id         String?
  voucher_id       String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  user    User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  store   Store?   @relation(fields: [store_id], references: [id], onDelete: SetNull)
  voucher Voucher? @relation(fields: [voucher_id], references: [id], onDelete: SetNull)

  items         OrderItem[]
  financial_txs FinancialTransaction[]
}

model OrderItem {
  id         String  @id
  order_id   String
  product_id String
  variant_id String?
  quantity   Int
  price      Int

  order   Order           @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variant_id], references: [id], onDelete: SetNull)
}

model Cart {
  id         String   @id
  user_id    String   @unique
  created_at DateTime @default(now())

  user  User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id         String  @id
  cart_id    String
  product_id String
  variant_id String?
  quantity   Int

  cart    Cart            @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variant_id], references: [id], onDelete: SetNull)
}

model Notification {
  id         String   @id
  user_id    String?
  title      String
  message    String   @db.Text
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Video {
  id          String   @id
  title       String?
  video_url   String   @db.Text
  creator_id  String
  product_id  String
  status      String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  views_count Int      @default(0)
  created_at  DateTime @default(now())

  creator User    @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model FinancialTransaction {
  id               String   @id
  order_id         String?
  transaction_type String // "PAYMENT", "PLATFORM_FEE", "AFFILIATE_COMMISSION", "REFUND", "SETTLEMENT"
  amount           Int
  sender_address   String // Địa chỉ ví người gửi
  receiver_address String // Địa chỉ ví người nhận
  status           String   @default("PENDING") // "PENDING", "BATCHED", "COMPLETED"
  batch_id         String?
  created_at       DateTime @default(now())

  order Order?       @relation(fields: [order_id], references: [id], onDelete: SetNull)
  batch MerkleBatch? @relation(fields: [batch_id], references: [id], onDelete: SetNull)
}

model MerkleBatch {
  id               String   @id
  merkle_root_hash String   @unique // Root hash được đẩy lên blockchain
  blockchain_tx    String? // Giao dịch băm trên chuỗi khối Polygon
  status           String   @default("PROCESSING") // "PROCESSING", "SUBMITTED", "FAILED"
  created_at       DateTime @default(now())

  transactions FinancialTransaction[]
}

model VtoSession {
  id          String   @id
  ip_address  String? // Quản lý khách vãng lai qua IP
  user_id     String? // Quản lý khách hàng đã đăng nhập
  usage_count Int      @default(0)
  last_used   DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)
}
